#
# https://help.github.com/articles/dealing-with-line-endings/
#

# Linux start script should use lf
/gradlew        text eol=lf

# These are Windows script files and should use crlf
*.bat           text eol=crlf
*.cmd           text eol=crlf

# Binary files should be left untouched
*.jar           binary

# Code files - force LF line endings for cross-platform consistency
*.kts           text eol=lf
*.kt            text eol=lf
*.java          text eol=lf
*.xml           text eol=lf
*.json          text eol=lf
*.toml          text eol=lf
*.properties    text eol=lf
*.sql           text eol=lf
*.md            text eol=lf

# Native image files
*.dll           binary
*.so             binary
*.dylib          binary